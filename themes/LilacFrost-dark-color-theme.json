{
	"$schema": "vscode://schemas/color-theme",
	"name": "Leo Dew Dark",
	"type": "vs-dark",
	"colors": {
		"editor.background": "#1A1828",
		"editor.foreground": "#E0DEE8",
		"editorCursor.foreground": "#C48EF0",
		"editor.lineHighlightBackground": "#1E1C30",

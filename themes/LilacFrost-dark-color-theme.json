		"editor.findMatchBackground": "#E4C47840",
		"editor.findMatchHighlightBackground": "#E4C47825",
		"editorLineNumber.foreground": "#58507A",
		"editorLineNumber.activeForeground": "#A878D0",
		"editorIndentGuide.background": "#222038",
		"editorIndentGuide.activeBackground": "#2E2850",
		"editorWhitespace.foreground": "#2E2850",
		"editorBracketMatch.background": "#2E2450",

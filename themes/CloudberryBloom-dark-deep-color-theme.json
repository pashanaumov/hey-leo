		"editorBracketHighlight.foreground6": "#A8D880",
		"editorError.foreground": "#F07878",
		"editorWarning.foreground": "#E8C878",
		"editorInfo.foreground": "#80C0E8",
		"editorGutter.modifiedBackground": "#5E82C9",
		"editorGutter.addedBackground": "#5CCC9D",
		"editorGutter.deletedBackground": "#D8645A",
		"editorOverviewRuler.border": "#180E22",
		"editorOverviewRuler.errorForeground": "#F07878",
		"editorOverviewRuler.warningForeground": "#E8C878",
		"editorOverviewRuler.infoForeground": "#80C0E8",
		"sideBar.background": "#0C0A10",
		"sideBar.foreground": "#A898B8",
		"sideBarTitle.foreground": "#C0B0D0",
		"sideBarSectionHeader.background": "#121018",
		"sideBarSectionHeader.foreground": "#C8B8D8",
		"list.activeSelectionBackground": "#1A0C21",
		"list.activeSelectionForeground": "#E0D8E8",
		"list.hoverBackground": "#13101A",
		"list.focusBackground": "#15091C",
		"list.highlightForeground": "#D870B4",
		"list.inactiveSelectionBackground": "#140C1A",
		"activityBar.background": "#0A090E",
		"activityBar.foreground": "#B85898",
		"activityBar.inactiveForeground": "#483B58",
		"activityBarBadge.background": "#D870B4",
		"activityBarBadge.foreground": "#FFFFFF",
		"statusBar.background": "#0D0B13",
		"statusBar.foreground": "#A898B8",
		"statusBar.debuggingBackground": "#210C2C",
		"statusBar.debuggingForeground": "#E0D8E8",
		"statusBar.noFolderBackground": "#121018",
		"titleBar.activeBackground": "#0A090E",
		"titleBar.activeForeground": "#C0B0D0",
		"titleBar.inactiveBackground": "#08070C",
		"titleBar.inactiveForeground": "#483B58",
		"editorGroupHeader.tabsBackground": "#0C0A10",
		"tab.activeBackground": "#121018",
		"tab.inactiveBackground": "#0C0A10",
		"tab.activeForeground": "#E0D8E8",
		"tab.inactiveForeground": "#483B58",
		"tab.activeBorderTop": "#D870B4",
		"tab.hoverBackground": "#121018",
		"tab.border": "#0C0A10",
		"panel.background": "#0E0C14",
		"panel.border": "#180E22",
		"panelTitle.activeForeground": "#E0D8E8",
		"panelTitle.activeBorder": "#D870B4",
		"panelTitle.inactiveForeground": "#483B58",
		"terminal.background": "#0F0D15",
		"terminal.foreground": "#E0D8E8",
		"terminal.ansiBlack": "#201828",
		"terminal.ansiRed": "#F07878",
		"terminal.ansiGreen": "#78E0A0",
		"terminal.ansiYellow": "#E8C878",
		"terminal.ansiBlue": "#80A8E0",
		"terminal.ansiMagenta": "#C068A8",
		"terminal.ansiCyan": "#68D0C8",
		"terminal.ansiWhite": "#B0A8C0",
		"terminal.ansiBrightBlack": "#383040",
		"terminal.ansiBrightRed": "#FF9090",
		"terminal.ansiBrightGreen": "#90F8B8",
		"terminal.ansiBrightYellow": "#FFE090",
		"terminal.ansiBrightBlue": "#98C0F8",
		"terminal.ansiBrightMagenta": "#D880C0",
		"terminal.ansiBrightCyan": "#80E8E0",
		"terminal.ansiBrightWhite": "#C8C0D8",
		"focusBorder": "#B85898",
		"input.background": "#121018",
		"input.foreground": "#E0D8E8",
		"input.border": "#180E22",
		"input.placeholderForeground": "#483B58",
		"inputOption.activeBorder": "#D870B4",
		"button.background": "#D870B4",
		"button.foreground": "#FFFFFF",
		"button.hoverBackground": "#F088CC",
		"button.secondaryBackground": "#1A0C21",
		"button.secondaryForeground": "#C0B0D0",
		"button.secondaryHoverBackground": "#15091C",
		"dropdown.background": "#121018",
		"dropdown.foreground": "#E0D8E8",
		"dropdown.border": "#180E22",
		"badge.background": "#D870B4",
		"badge.foreground": "#FFFFFF",
		"progressBar.background": "#D870B4",
		"scrollbarSlider.background": "#210C2C88",
		"scrollbarSlider.hoverBackground": "#15091C88",
		"scrollbarSlider.activeBackground": "#98407899",
		"minimap.selectionHighlight": "#D870B440",
		"minimapSlider.background": "#210C2C44",
		"minimapSlider.hoverBackground": "#15091C66",
		"minimapSlider.activeBackground": "#98407888",
		"breadcrumb.foreground": "#887898",
		"breadcrumb.focusForeground": "#C0B0D0",
		"breadcrumb.activeSelectionForeground": "#E0D8E8",
		"notificationCenter.border": "#180E22",
		"notifications.background": "#121018",
		"notifications.foreground": "#E0D8E8",
		"notificationLink.foreground": "#D870B4",
		"peekView.border": "#B85898",
		"peekViewEditor.background": "#121018",
		"peekViewResult.background": "#0C0A10",
		"peekViewTitle.background": "#121018",
		"peekViewEditor.matchHighlightBackground": "#D4B06040",
		"peekViewResult.matchHighlightBackground": "#D4B06040",
		"gitDecoration.modifiedResourceForeground": "#80A8E0",
		"gitDecoration.deletedResourceForeground": "#F07878",
		"gitDecoration.untrackedResourceForeground": "#78E0A0",
		"gitDecoration.ignoredResourceForeground": "#483B58",
		"gitDecoration.conflictingResourceForeground": "#E8C878",
		"diffEditor.insertedTextBackground": "#78E0A018",
		"diffEditor.removedTextBackground": "#F0787818",
		"editorWidget.background": "#121018",
		"editorWidget.border": "#180E22",
		"editorSuggestWidget.background": "#121018",
		"editorSuggestWidget.border": "#180E22",
		"editorSuggestWidget.foreground": "#E0D8E8",
		"editorSuggestWidget.selectedBackground": "#1A0C21",
		"editorSuggestWidget.highlightForeground": "#D870B4",
		"editorHoverWidget.background": "#121018",
		"editorHoverWidget.border": "#180E22"
	},
	"tokenColors": [
		{
			"scope": "comment",
			"settings": {
				"foreground": "#644858",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.other"
			],
			"settings": {
				"foreground": "#D870B4",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"storage.type",
				"storage.modifier",
				"storage"
			],
			"settings": {
				"foreground": "#D870B4",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from"
			],
			"settings": {
				"foreground": "#A85898",
				"fontStyle": ""
			}
		},
		{
			"scope": "string",
			"settings": {
				"foreground": "#6CD4C8"
			}
		},
		{
			"scope": "string.regexp",
			"settings": {
				"foreground": "#58C8C0"
			}
		},
		{
			"scope": "constant.character.escape",
			"settings": {
				"foreground": "#4CC0B8",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "variable",
			"settings": {
				"foreground": "#C0B8C8"
			}
		},
		{
			"scope": "variable.parameter",
			"settings": {
				"foreground": "#B0A8B8",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable.other.property",
				"support.variable.property"
			],
			"settings": {
				"foreground": "#C8C0D0"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call"
			],
			"settings": {
				"foreground": "#D4B060",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"support.class",
				"entity.name.class"
			],
			"settings": {
				"foreground": "#94CC94",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"entity.name.enum",
				"entity.name.type.enum"
			],
			"settings": {
				"foreground": "#A8D880",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"constant",
				"constant.language",
				"support.constant",
				"variable.other.constant"
			],
			"settings": {
				"foreground": "#F09070",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"constant.numeric",
				"number"
			],
			"settings": {
				"foreground": "#E88870"
			}
		},
		{
			"scope": [
				"keyword.operator",
				"operator",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#B060A8"
			}
		},
		{
			"scope": "punctuation",
			"settings": {
				"foreground": "#9888A8"
			}
		},
		{
			"scope": [
				"punctuation.definition.block",
				"punctuation.definition.parameters",
				"punctuation.section",
				"punctuation.definition.arguments"
			],
			"settings": {
				"foreground": "#A898B8"
			}
		},
		{
			"scope": "entity.name.tag",
			"settings": {
				"foreground": "#94CC94"
			}
		},
		{
			"scope": "entity.other.attribute-name",
			"settings": {
				"foreground": "#D4B060",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"meta.decorator",
				"punctuation.decorator"
			],
			"settings": {
				"foreground": "#7CB4DC",
				"fontStyle": "italic"
			}
		},
		{
			"scope": "support.type",
			"settings": {
				"foreground": "#D470B0"
			}
		},
		{
			"scope": "markup.heading",
			"settings": {
				"foreground": "#D870B4",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "markup.underline",
			"settings": {
				"fontStyle": "underline"
			}
		},
		{
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#78E0A0"
			}
		},
		{
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#F07878"
			}
		},
		{
			"scope": "markup.changed",
			"settings": {
				"foreground": "#D4B060"
			}
		},
		{
			"scope": [
				"markup.inline.raw",
				"markup.fenced_code"
			],
			"settings": {
				"foreground": "#6CD4C8"
			}
		},
		{
			"scope": "meta.embedded",
			"settings": {
				"foreground": "#E0D8E8"
			}
		},
		{
			"scope": "invalid",
			"settings": {
				"foreground": "#FFFFFF",
				"fontStyle": "underline"
			}
		}
	]
}

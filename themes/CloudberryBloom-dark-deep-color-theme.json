		"editor.findMatchBackground": "#D4B06040",
		"editor.findMatchHighlightBackground": "#D4B06025",
		"editorLineNumber.foreground": "#483B58",
		"editorLineNumber.activeForeground": "#B858A0",
		"editorIndentGuide.background": "#141221",

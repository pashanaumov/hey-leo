{
	"$schema": "vscode://schemas/color-theme",
	"name": "Leo Dusk Dark Deep",
	"type": "vs-dark",
	"colors": {
		"editor.background": "#0F0D15",
		"editor.foreground": "#E0D8E8",
		"editorCursor.foreground": "#D870B4",
		"editor.lineHighlightBackground": "#121018",

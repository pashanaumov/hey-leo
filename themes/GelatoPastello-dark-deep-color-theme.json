		"editor.findMatchBackground": "#B898D440",
		"editor.findMatchHighlightBackground": "#B898D425",
		"editorLineNumber.foreground": "#4D4634",
		"editorLineNumber.activeForeground": "#B89840",
		"editorIndentGuide.background": "#15130E",
		"editorIndentGuide.activeBackground": "#1C1A12",
		"editorWhitespace.foreground": "#1C1A12",
		"editorBracketMatch.background": "#181209",

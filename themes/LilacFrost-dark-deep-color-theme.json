{
	"$schema": "vscode://schemas/color-theme",
	"name": "Leo Dew Dark Deep",
	"type": "vs-dark",
	"colors": {
		"editor.background": "#0D0B14",
		"editor.foreground": "#E0DEE8",
		"editorCursor.foreground": "#C48EF0",
		"editor.lineHighlightBackground": "#12101C",
		"editor.selectionBackground": "#2C2050",
		"editor.inactiveSelectionBackground": "#201838",
		"editor.wordHighlightBackground": "#2C205044",
		"editor.wordHighlightStrongBackground": "#2C205544",
		"editor.findMatchBackground": "#E4C47840",
		"editor.findMatchHighlightBackground": "#E4C47825",
		"editorLineNumber.foreground": "#484068",
		"editorLineNumber.activeForeground": "#A878D0",
		"editorIndentGuide.background": "#161428",
		"editorIndentGuide.activeBackground": "#201C3C",
		"editorWhitespace.foreground": "#201C3C",
		"editorBracketMatch.background": "#221840",

{
	"$schema": "vscode://schemas/color-theme",
	"name": "Leo Dew Dark",
	"type": "vs-dark",
	"colors": {
		"editor.background": "#1A1828",
		"editor.foreground": "#CCCAD5",
		"editorCursor.foreground": "#C48EF0",
		"editor.lineHighlightBackground": "#CCCAD50F",
		"editor.selectionBackground": "#9795A23D",
		"editor.inactiveSelectionBackground": "#807E8B2E",
		"editor.wordHighlightBackground": "#9795A224",
		"editor.wordHighlightStrongBackground": "#80C0E82E",
		"editor.findMatchBackground": "#F0A88857",
		"editor.findMatchHighlightBackground": "#80C0E83D",
		"editorLineNumber.foreground": "#686674",
		"editorLineNumber.activeForeground": "#C48EF0",
		"editorIndentGuide.background": "#333140",
		"editorIndentGuide.activeBackground": "#413F4E",
		"editorWhitespace.foreground": "#9795A259",
		"editorBracketMatch.background": "#9795A21A",
		"editorBracketMatch.border": "#9795A2",
		"editorBracketHighlight.foreground1": "#C48EF0",
		"editorBracketHighlight.foreground2": "#7CE4D8",
		"editorBracketHighlight.foreground3": "#E4C478",
		"editorBracketHighlight.foreground4": "#F0A888",
		"editorBracketHighlight.foreground5": "#80C0E8",
		"editorBracketHighlight.foreground6": "#B4D088",
		"editorError.foreground": "#F07878",
		"editorWarning.foreground": "#F0A888",
		"editorInfo.foreground": "#80C0E8",
		"editorGutter.modifiedBackground": "#80C0E8",
		"editorGutter.addedBackground": "#B4D088",
		"editorGutter.deletedBackground": "#F07878",
		"editorOverviewRuler.border": "#333140",
		"editorOverviewRuler.errorForeground": "#F07878",
		"editorOverviewRuler.warningForeground": "#F0A888",
		"editorOverviewRuler.infoForeground": "#80C0E8",
		"sideBar.background": "#181624",
		"sideBar.foreground": "#CCCAD5",
		"sideBarTitle.foreground": "#C48EF0",
		"sideBarSectionHeader.background": "#181624",
		"sideBarSectionHeader.foreground": "#CCCAD5",
		"list.activeSelectionBackground": "#282636",
		"list.activeSelectionForeground": "#CCCAD5",
		"list.hoverBackground": "#2826368C",
		"list.focusBackground": "#282636",
		"list.highlightForeground": "#C48EF0",
		"list.inactiveSelectionBackground": "#282636",
		"activityBar.background": "#161422",
		"activityBar.foreground": "#C48EF0",
		"activityBar.inactiveForeground": "#686674",
		"activityBarBadge.background": "#C48EF0",
		"activityBarBadge.foreground": "#161422",
		"statusBar.background": "#161422",
		"statusBar.foreground": "#CCCAD5",
		"statusBar.debuggingBackground": "#F0A888",
		"statusBar.debuggingForeground": "#161422",
		"statusBar.noFolderBackground": "#161422",
		"titleBar.activeBackground": "#161422",
		"titleBar.activeForeground": "#CCCAD5",
		"titleBar.inactiveBackground": "#161422",
		"titleBar.inactiveForeground": "#686674",
		"editorGroupHeader.tabsBackground": "#161422",
		"tab.activeBackground": "#1A1828",
		"tab.inactiveBackground": "#181624",
		"tab.activeForeground": "#C48EF0",
		"tab.inactiveForeground": "#686674",
		"tab.activeBorderTop": "#C48EF0",
		"tab.hoverBackground": "#232131",
		"tab.border": "#181624",
		"panel.background": "#1A1828",
		"panel.border": "#413F4E",
		"panelTitle.activeForeground": "#CCCAD5",
		"panelTitle.activeBorder": "#C48EF0",
		"panelTitle.inactiveForeground": "#686674",
		"terminal.background": "#1A1828",
		"terminal.foreground": "#CCCAD5",
		"terminal.ansiBlack": "#282636",
		"terminal.ansiRed": "#F07878",
		"terminal.ansiGreen": "#B4D088",
		"terminal.ansiYellow": "#E4C478",
		"terminal.ansiBlue": "#80C0E8",
		"terminal.ansiMagenta": "#C48EF0",
		"terminal.ansiCyan": "#7CE4D8",
		"terminal.ansiWhite": "#9795A2",
		"terminal.ansiBrightBlack": "#686674",
		"terminal.ansiBrightRed": "#F18383",
		"terminal.ansiBrightGreen": "#BAD492",
		"terminal.ansiBrightYellow": "#E6C983",
		"terminal.ansiBrightBlue": "#8AC5EA",
		"terminal.ansiBrightMagenta": "#C997F1",
		"terminal.ansiBrightCyan": "#86E6DB",
		"terminal.ansiBrightWhite": "#CCCAD5",
		"focusBorder": "#C48EF0",
		"input.background": "#282636",
		"input.foreground": "#CCCAD5",
		"input.border": "#413F4E",
		"input.placeholderForeground": "#686674",
		"inputOption.activeBorder": "#C48EF0",
		"button.background": "#C48EF0",
		"button.foreground": "#161422",
		"button.hoverBackground": "#C895F1",
		"button.secondaryBackground": "#333140",
		"button.secondaryForeground": "#CCCAD5",
		"button.secondaryHoverBackground": "#43414F",
		"dropdown.background": "#181624",
		"dropdown.foreground": "#CCCAD5",
		"dropdown.border": "#413F4E",
		"badge.background": "#333140",
		"badge.foreground": "#CCCAD5",
		"progressBar.background": "#C48EF0",
		"scrollbarSlider.background": "#413F4E80",
		"scrollbarSlider.hoverBackground": "#686674",
		"scrollbarSlider.activeBackground": "#28263673",
		"minimap.selectionHighlight": "#413F4EBF",
		"minimapSlider.background": "#C48EF033",
		"minimapSlider.hoverBackground": "#C48EF066",
		"minimapSlider.activeBackground": "#C48EF099",
		"breadcrumb.foreground": "#807E8B",
		"breadcrumb.focusForeground": "#C48EF0",
		"breadcrumb.activeSelectionForeground": "#C48EF0",
		"notificationCenter.border": "#C48EF0",
		"notifications.background": "#181624",
		"notifications.foreground": "#CCCAD5",
		"notificationLink.foreground": "#80C0E8",
		"peekView.border": "#C48EF0",
		"peekViewEditor.background": "#181624",
		"peekViewResult.background": "#181624",
		"peekViewTitle.background": "#1A1828",
		"peekViewEditor.matchHighlightBackground": "#80C0E84D",
		"peekViewResult.matchHighlightBackground": "#80C0E84D",
		"gitDecoration.modifiedResourceForeground": "#80C0E8",
		"gitDecoration.deletedResourceForeground": "#F07878",
		"gitDecoration.untrackedResourceForeground": "#B4D088",
		"gitDecoration.ignoredResourceForeground": "#686674",
		"gitDecoration.conflictingResourceForeground": "#C48EF0",
		"diffEditor.insertedTextBackground": "#B4D0882E",
		"diffEditor.removedTextBackground": "#F078782E",
		"editorWidget.background": "#181624",
		"editorWidget.border": "#413F4E",
		"editorSuggestWidget.background": "#181624",
		"editorSuggestWidget.border": "#413F4E",
		"editorSuggestWidget.foreground": "#CCCAD5",
		"editorSuggestWidget.selectedBackground": "#282636",
		"editorSuggestWidget.highlightForeground": "#C48EF0",
		"editorHoverWidget.background": "#181624",
		"editorHoverWidget.border": "#413F4E"
	},
	"semanticHighlighting": true,
	"semanticTokenColors": {
		"enumMember": {
			"foreground": "#B4D088"
		},
		"function": {
			"foreground": "#80C0E8",
			"fontStyle": "italic"
		},
		"method": {
			"foreground": "#80C0E8",
			"fontStyle": "italic"
		},
		"keyword": {
			"foreground": "#C48EF0"
		},
		"number": {
			"foreground": "#F0A888"
		},
		"boolean": {
			"foreground": "#F0A888"
		},
		"parameter": {
			"foreground": "#CABCDB",
			"fontStyle": "italic"
		},
		"property": {
			"foreground": "#CCCAD5"
		},
		"variable.defaultLibrary": {
			"foreground": "#CABCDB"
		},
		"variable.readonly": {
			"foreground": "#CCCAD5"
		},
		"property.readonly": {
			"foreground": "#CCCAD5"
		},
		"class": {
			"foreground": "#E4C478",
			"fontStyle": "italic"
		},
		"type": {
			"foreground": "#E4C478",
			"fontStyle": "italic"
		},
		"interface": {
			"foreground": "#E4C478",
			"fontStyle": "italic"
		},
		"enum": {
			"foreground": "#E4C478",
			"fontStyle": "italic"
		},
		"namespace": {
			"foreground": "#E4C478"
		},
		"typeParameter": {
			"foreground": "#CABCDB"
		},
		"decorator": {
			"foreground": "#F0A888",
			"fontStyle": "italic"
		},
		"macro": {
			"foreground": "#80C0E8"
		},
		"selfKeyword": {
			"foreground": "#F07878"
		}
	},
	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#686674",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"text",
				"source",
				"variable",
				"variable.other.readwrite"
			],
			"settings": {
				"foreground": "#CCCAD5"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.other"
			],
			"settings": {
				"foreground": "#C48EF0",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"storage.type",
				"storage.modifier",
				"storage"
			],
			"settings": {
				"foreground": "#C48EF0",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from"
			],
			"settings": {
				"foreground": "#C9B4DF",
				"fontStyle": ""
			}
		},
		{
			"scope": "string",
			"settings": {
				"foreground": "#7CE4D8"
			}
		},
		{
			"scope": "string.regexp",
			"settings": {
				"foreground": "#95C6E0"
			}
		},
		{
			"scope": "constant.character.escape",
			"settings": {
				"foreground": "#9FBBE4"
			}
		},
		{
			"scope": "variable.parameter",
			"settings": {
				"foreground": "#CABCDB",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable.other.property",
				"support.variable.property",
				"variable.object.property"
			],
			"settings": {
				"foreground": "#CCCAD5"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call",
				"meta.function-call.method"
			],
			"settings": {
				"foreground": "#80C0E8",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"support.class",
				"entity.name.class",
				"entity.name.namespace"
			],
			"settings": {
				"foreground": "#E4C478",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"entity.name.enum",
				"entity.name.type.enum"
			],
			"settings": {
				"foreground": "#E4C478",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"constant",
				"constant.language",
				"support.constant",
				"variable.other.constant"
			],
			"settings": {
				"foreground": "#F0A888"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"number"
			],
			"settings": {
				"foreground": "#F0A888"
			}
		},
		{
			"scope": [
				"keyword.operator",
				"operator",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#7CE4D8"
			}
		},
		{
			"scope": "punctuation",
			"settings": {
				"foreground": "#807E8B"
			}
		},
		{
			"scope": [
				"punctuation.definition.block",
				"punctuation.definition.parameters",
				"punctuation.section",
				"punctuation.definition.arguments"
			],
			"settings": {
				"foreground": "#9795A2"
			}
		},
		{
			"scope": "entity.name.tag",
			"settings": {
				"foreground": "#C48EF0"
			}
		},
		{
			"scope": "entity.other.attribute-name",
			"settings": {
				"foreground": "#80C0E8",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"meta.decorator",
				"punctuation.decorator"
			],
			"settings": {
				"foreground": "#F0A888",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"support.type",
				"meta.type",
				"meta.type-alias"
			],
			"settings": {
				"foreground": "#E4C478"
			}
		},
		{
			"scope": [
				"support.function.builtin",
				"variable.language.this"
			],
			"settings": {
				"foreground": "#F07878"
			}
		},
		{
			"scope": "markup.heading",
			"settings": {
				"foreground": "#C48EF0",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "markup.underline",
			"settings": {
				"fontStyle": "underline"
			}
		},
		{
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#B4D088"
			}
		},
		{
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#F07878"
			}
		},
		{
			"scope": "markup.changed",
			"settings": {
				"foreground": "#80C0E8"
			}
		},
		{
			"scope": [
				"markup.inline.raw",
				"markup.fenced_code"
			],
			"settings": {
				"foreground": "#7CE4D8"
			}
		},
		{
			"scope": "meta.embedded",
			"settings": {
				"foreground": "#CCCAD5"
			}
		},
		{
			"scope": "invalid",
			"settings": {
				"foreground": "#F07878",
				"fontStyle": "underline"
			}
		}
	]
}

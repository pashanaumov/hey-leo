{
	"$schema": "vscode://schemas/color-theme",
	"name": "Leo Dew Dark Deep",
	"type": "vs-dark",
	"colors": {
		"editor.background": "#0D0B14",
		"editor.foreground": "#CBC9D3",
		"editorCursor.foreground": "#C48EF0",
		"editor.lineHighlightBackground": "#CBC9D30F",
		"editor.selectionBackground": "#93919A3D",
		"editor.inactiveSelectionBackground": "#7A78812E",
		"editor.wordHighlightBackground": "#93919A24",
		"editor.wordHighlightStrongBackground": "#80C0E82E",
		"editor.findMatchBackground": "#F0A88857",
		"editor.findMatchHighlightBackground": "#80C0E83D",
		"editorLineNumber.foreground": "#605E68",
		"editorLineNumber.activeForeground": "#C48EF0",
		"editorIndentGuide.background": "#28262F",
		"editorIndentGuide.activeBackground": "#37353E",
		"editorWhitespace.foreground": "#93919A59",
		"editorBracketMatch.background": "#93919A1A",
		"editorBracketMatch.border": "#93919A",
		"editorBracketHighlight.foreground1": "#C48EF0",
		"editorBracketHighlight.foreground2": "#7CE4D8",
		"editorBracketHighlight.foreground3": "#E4C478",
		"editorBracketHighlight.foreground4": "#F0A888",
		"editorBracketHighlight.foreground5": "#80C0E8",
		"editorBracketHighlight.foreground6": "#B4D088",
		"editorError.foreground": "#F07878",
		"editorWarning.foreground": "#F0A888",
		"editorInfo.foreground": "#80C0E8",
		"editorGutter.modifiedBackground": "#80C0E8",
		"editorGutter.addedBackground": "#B4D088",
		"editorGutter.deletedBackground": "#F07878",
		"editorOverviewRuler.border": "#28262F",
		"editorOverviewRuler.errorForeground": "#F07878",
		"editorOverviewRuler.warningForeground": "#F0A888",
		"editorOverviewRuler.infoForeground": "#80C0E8",
		"sideBar.background": "#0C0A12",
		"sideBar.foreground": "#CBC9D3",
		"sideBarTitle.foreground": "#C48EF0",
		"sideBarSectionHeader.background": "#0C0A12",
		"sideBarSectionHeader.foreground": "#CBC9D3",
		"list.activeSelectionBackground": "#1C1A23",
		"list.activeSelectionForeground": "#CBC9D3",
		"list.hoverBackground": "#1C1A238C",
		"list.focusBackground": "#1C1A23",
		"list.highlightForeground": "#C48EF0",
		"list.inactiveSelectionBackground": "#1C1A23",
		"activityBar.background": "#0B0911",
		"activityBar.foreground": "#C48EF0",
		"activityBar.inactiveForeground": "#605E68",
		"activityBarBadge.background": "#C48EF0",
		"activityBarBadge.foreground": "#0B0911",
		"statusBar.background": "#0B0911",
		"statusBar.foreground": "#CBC9D3",
		"statusBar.debuggingBackground": "#F0A888",
		"statusBar.debuggingForeground": "#0B0911",
		"statusBar.noFolderBackground": "#0B0911",
		"titleBar.activeBackground": "#0B0911",
		"titleBar.activeForeground": "#CBC9D3",
		"titleBar.inactiveBackground": "#0B0911",
		"titleBar.inactiveForeground": "#605E68",
		"editorGroupHeader.tabsBackground": "#0B0911",
		"tab.activeBackground": "#0D0B14",
		"tab.inactiveBackground": "#0C0A12",
		"tab.activeForeground": "#C48EF0",
		"tab.inactiveForeground": "#605E68",
		"tab.activeBorderTop": "#C48EF0",
		"tab.hoverBackground": "#17151D",
		"tab.border": "#0C0A12",
		"panel.background": "#0D0B14",
		"panel.border": "#37353E",
		"panelTitle.activeForeground": "#CBC9D3",
		"panelTitle.activeBorder": "#C48EF0",
		"panelTitle.inactiveForeground": "#605E68",
		"terminal.background": "#0D0B14",
		"terminal.foreground": "#CBC9D3",
		"terminal.ansiBlack": "#1C1A23",
		"terminal.ansiRed": "#F07878",
		"terminal.ansiGreen": "#B4D088",
		"terminal.ansiYellow": "#E4C478",
		"terminal.ansiBlue": "#80C0E8",
		"terminal.ansiMagenta": "#C48EF0",
		"terminal.ansiCyan": "#7CE4D8",
		"terminal.ansiWhite": "#93919A",
		"terminal.ansiBrightBlack": "#605E68",
		"terminal.ansiBrightRed": "#F18383",
		"terminal.ansiBrightGreen": "#BAD492",
		"terminal.ansiBrightYellow": "#E6C983",
		"terminal.ansiBrightBlue": "#8AC5EA",
		"terminal.ansiBrightMagenta": "#C997F1",
		"terminal.ansiBrightCyan": "#86E6DB",
		"terminal.ansiBrightWhite": "#CBC9D3",
		"focusBorder": "#C48EF0",
		"input.background": "#1C1A23",
		"input.foreground": "#CBC9D3",
		"input.border": "#37353E",
		"input.placeholderForeground": "#605E68",
		"inputOption.activeBorder": "#C48EF0",
		"button.background": "#C48EF0",
		"button.foreground": "#0B0911",
		"button.hoverBackground": "#C895F1",
		"button.secondaryBackground": "#28262F",
		"button.secondaryForeground": "#CBC9D3",
		"button.secondaryHoverBackground": "#393740",
		"dropdown.background": "#0C0A12",
		"dropdown.foreground": "#CBC9D3",
		"dropdown.border": "#37353E",
		"badge.background": "#28262F",
		"badge.foreground": "#CBC9D3",
		"progressBar.background": "#C48EF0",
		"scrollbarSlider.background": "#37353E80",
		"scrollbarSlider.hoverBackground": "#605E68",
		"scrollbarSlider.activeBackground": "#1C1A2373",
		"minimap.selectionHighlight": "#37353EBF",
		"minimapSlider.background": "#C48EF033",
		"minimapSlider.hoverBackground": "#C48EF066",
		"minimapSlider.activeBackground": "#C48EF099",
		"breadcrumb.foreground": "#7A7881",
		"breadcrumb.focusForeground": "#C48EF0",
		"breadcrumb.activeSelectionForeground": "#C48EF0",
		"notificationCenter.border": "#C48EF0",
		"notifications.background": "#0C0A12",
		"notifications.foreground": "#CBC9D3",
		"notificationLink.foreground": "#80C0E8",
		"peekView.border": "#C48EF0",
		"peekViewEditor.background": "#0C0A12",
		"peekViewResult.background": "#0C0A12",
		"peekViewTitle.background": "#0D0B14",
		"peekViewEditor.matchHighlightBackground": "#80C0E84D",
		"peekViewResult.matchHighlightBackground": "#80C0E84D",
		"gitDecoration.modifiedResourceForeground": "#80C0E8",
		"gitDecoration.deletedResourceForeground": "#F07878",
		"gitDecoration.untrackedResourceForeground": "#B4D088",
		"gitDecoration.ignoredResourceForeground": "#605E68",
		"gitDecoration.conflictingResourceForeground": "#C48EF0",
		"diffEditor.insertedTextBackground": "#B4D0882E",
		"diffEditor.removedTextBackground": "#F078782E",
		"editorWidget.background": "#0C0A12",
		"editorWidget.border": "#37353E",
		"editorSuggestWidget.background": "#0C0A12",
		"editorSuggestWidget.border": "#37353E",
		"editorSuggestWidget.foreground": "#CBC9D3",
		"editorSuggestWidget.selectedBackground": "#1C1A23",
		"editorSuggestWidget.highlightForeground": "#C48EF0",
		"editorHoverWidget.background": "#0C0A12",
		"editorHoverWidget.border": "#37353E"
	},
	"semanticHighlighting": true,
	"semanticTokenColors": {
		"enumMember": {
			"foreground": "#B4D088"
		},
		"function": {
			"foreground": "#80C0E8",
			"fontStyle": "italic"
		},
		"method": {
			"foreground": "#80C0E8",
			"fontStyle": "italic"
		},
		"keyword": {
			"foreground": "#C48EF0"
		},
		"number": {
			"foreground": "#F0A888"
		},
		"boolean": {
			"foreground": "#F0A888"
		},
		"parameter": {
			"foreground": "#C9BBDA",
			"fontStyle": "italic"
		},
		"property": {
			"foreground": "#CBC9D3"
		},
		"variable.defaultLibrary": {
			"foreground": "#C9BBDA"
		},
		"variable.readonly": {
			"foreground": "#CBC9D3"
		},
		"property.readonly": {
			"foreground": "#CBC9D3"
		},
		"class": {
			"foreground": "#E4C478",
			"fontStyle": "italic"
		},
		"type": {
			"foreground": "#E4C478",
			"fontStyle": "italic"
		},
		"interface": {
			"foreground": "#E4C478",
			"fontStyle": "italic"
		},
		"enum": {
			"foreground": "#E4C478",
			"fontStyle": "italic"
		},
		"namespace": {
			"foreground": "#E4C478"
		},
		"typeParameter": {
			"foreground": "#C9BBDA"
		},
		"decorator": {
			"foreground": "#F0A888",
			"fontStyle": "italic"
		},
		"macro": {
			"foreground": "#80C0E8"
		},
		"selfKeyword": {
			"foreground": "#F07878"
		}
	},
	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#605E68",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"text",
				"source",
				"variable",
				"variable.other.readwrite"
			],
			"settings": {
				"foreground": "#CBC9D3"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.other"
			],
			"settings": {
				"foreground": "#C48EF0",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"storage.type",
				"storage.modifier",
				"storage"
			],
			"settings": {
				"foreground": "#C48EF0",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from"
			],
			"settings": {
				"foreground": "#C8B4DD",
				"fontStyle": ""
			}
		},
		{
			"scope": "string",
			"settings": {
				"foreground": "#7CE4D8"
			}
		},
		{
			"scope": "string.regexp",
			"settings": {
				"foreground": "#95C6E0"
			}
		},
		{
			"scope": "constant.character.escape",
			"settings": {
				"foreground": "#9FBBE4"
			}
		},
		{
			"scope": "variable.parameter",
			"settings": {
				"foreground": "#C9BBDA",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable.other.property",
				"support.variable.property",
				"variable.object.property"
			],
			"settings": {
				"foreground": "#CBC9D3"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call",
				"meta.function-call.method"
			],
			"settings": {
				"foreground": "#80C0E8",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"support.class",
				"entity.name.class",
				"entity.name.namespace"
			],
			"settings": {
				"foreground": "#E4C478",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"entity.name.enum",
				"entity.name.type.enum"
			],
			"settings": {
				"foreground": "#E4C478",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"constant",
				"constant.language",
				"support.constant",
				"variable.other.constant"
			],
			"settings": {
				"foreground": "#F0A888"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"number"
			],
			"settings": {
				"foreground": "#F0A888"
			}
		},
		{
			"scope": [
				"keyword.operator",
				"operator",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#7CE4D8"
			}
		},
		{
			"scope": "punctuation",
			"settings": {
				"foreground": "#7A7881"
			}
		},
		{
			"scope": [
				"punctuation.definition.block",
				"punctuation.definition.parameters",
				"punctuation.section",
				"punctuation.definition.arguments"
			],
			"settings": {
				"foreground": "#93919A"
			}
		},
		{
			"scope": "entity.name.tag",
			"settings": {
				"foreground": "#C48EF0"
			}
		},
		{
			"scope": "entity.other.attribute-name",
			"settings": {
				"foreground": "#80C0E8",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"meta.decorator",
				"punctuation.decorator"
			],
			"settings": {
				"foreground": "#F0A888",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"support.type",
				"meta.type",
				"meta.type-alias"
			],
			"settings": {
				"foreground": "#E4C478"
			}
		},
		{
			"scope": [
				"support.function.builtin",
				"variable.language.this"
			],
			"settings": {
				"foreground": "#F07878"
			}
		},
		{
			"scope": "markup.heading",
			"settings": {
				"foreground": "#C48EF0",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "markup.underline",
			"settings": {
				"fontStyle": "underline"
			}
		},
		{
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#B4D088"
			}
		},
		{
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#F07878"
			}
		},
		{
			"scope": "markup.changed",
			"settings": {
				"foreground": "#80C0E8"
			}
		},
		{
			"scope": [
				"markup.inline.raw",
				"markup.fenced_code"
			],
			"settings": {
				"foreground": "#7CE4D8"
			}
		},
		{
			"scope": "meta.embedded",
			"settings": {
				"foreground": "#CBC9D3"
			}
		},
		{
			"scope": "invalid",
			"settings": {
				"foreground": "#F07878",
				"fontStyle": "underline"
			}
		}
	]
}

		"editorError.foreground": "#F07878",
		"editorWarning.foreground": "#E8C878",
		"editorInfo.foreground": "#80C0E8",
		"editorGutter.modifiedBackground": "#5E82C9",
		"editorGutter.addedBackground": "#5CCC9D",
		"editorGutter.deletedBackground": "#D8645A",
		"editorOverviewRuler.border": "#282418",
		"editorOverviewRuler.errorForeground": "#F07878",
		"editorOverviewRuler.warningForeground": "#E8C878",
		"editorOverviewRuler.infoForeground": "#80C0E8",
		"sideBar.background": "#141310",
		"sideBar.foreground": "#A8A098",
		"sideBarTitle.foreground": "#C0B8B0",
		"sideBarSectionHeader.background": "#201E18",
		"sideBarSectionHeader.foreground": "#C8C0B8",
		"list.activeSelectionBackground": "#302818",
		"list.activeSelectionForeground": "#E8E4D8",
		"list.hoverBackground": "#201E16",
		"list.focusBackground": "#281E10",
		"list.highlightForeground": "#D4B46C",
		"list.inactiveSelectionBackground": "#262014",
		"activityBar.background": "#111008",
		"activityBar.foreground": "#B89848",
		"activityBar.inactiveForeground": "#5E5640",
		"activityBarBadge.background": "#D4B46C",
		"activityBarBadge.foreground": "#FFFFFF",
		"statusBar.background": "#161514",
		"statusBar.foreground": "#A8A098",
		"statusBar.debuggingBackground": "#382C18",
		"statusBar.debuggingForeground": "#E8E4D8",
		"statusBar.noFolderBackground": "#201E18",
		"titleBar.activeBackground": "#111008",
		"titleBar.activeForeground": "#C0B8B0",
		"titleBar.inactiveBackground": "#0E0D07",
		"titleBar.inactiveForeground": "#5E5640",
		"editorGroupHeader.tabsBackground": "#141310",
		"tab.activeBackground": "#1E1D1C",
		"tab.inactiveBackground": "#141310",
		"tab.activeForeground": "#E8E4D8",
		"tab.inactiveForeground": "#5E5640",
		"tab.activeBorderTop": "#D4B46C",
		"tab.hoverBackground": "#201E18",
		"tab.border": "#141310",
		"panel.background": "#181716",
		"panel.border": "#282418",
		"panelTitle.activeForeground": "#E8E4D8",
		"panelTitle.activeBorder": "#D4B46C",
		"panelTitle.inactiveForeground": "#5E5640",
		"terminal.background": "#1A1918",
		"terminal.foreground": "#E8E4D8",
		"terminal.ansiBlack": "#282018",
		"terminal.ansiRed": "#F07878",
		"terminal.ansiGreen": "#78E0A0",
		"terminal.ansiYellow": "#E8C878",
		"terminal.ansiBlue": "#80A8E0",
		"terminal.ansiMagenta": "#C880A8",
		"terminal.ansiCyan": "#68D0B8",
		"terminal.ansiWhite": "#B0A898",
		"terminal.ansiBrightBlack": "#403830",
		"terminal.ansiBrightRed": "#FF9090",
		"terminal.ansiBrightGreen": "#90F8B8",
		"terminal.ansiBrightYellow": "#FFE090",
		"terminal.ansiBrightBlue": "#98C0F8",
		"terminal.ansiBrightMagenta": "#E098C0",
		"terminal.ansiBrightCyan": "#80E8D0",
		"terminal.ansiBrightWhite": "#C8C0B0",
		"focusBorder": "#B89848",
		"input.background": "#1E1D1C",
		"input.foreground": "#E8E4D8",
		"input.border": "#282418",
		"input.placeholderForeground": "#5E5640",
		"inputOption.activeBorder": "#D4B46C",
		"button.background": "#D4B46C",
		"button.foreground": "#FFFFFF",
		"button.hoverBackground": "#ECCC84",
		"button.secondaryBackground": "#302818",
		"button.secondaryForeground": "#C0B8B0",
		"button.secondaryHoverBackground": "#281E10",
		"dropdown.background": "#1E1D1C",
		"dropdown.foreground": "#E8E4D8",
		"dropdown.border": "#282418",
		"badge.background": "#D4B46C",
		"badge.foreground": "#FFFFFF",
		"progressBar.background": "#D4B46C",
		"scrollbarSlider.background": "#382C1888",
		"scrollbarSlider.hoverBackground": "#281E1088",
		"scrollbarSlider.activeBackground": "#98782899",
		"minimap.selectionHighlight": "#D4B46C40",
		"minimapSlider.background": "#382C1844",
		"minimapSlider.hoverBackground": "#281E1066",
		"minimapSlider.activeBackground": "#98782888",
		"breadcrumb.foreground": "#90887A",
		"breadcrumb.focusForeground": "#C0B8B0",
		"breadcrumb.activeSelectionForeground": "#E8E4D8",
		"notificationCenter.border": "#282418",
		"notifications.background": "#1E1D1C",
		"notifications.foreground": "#E8E4D8",
		"notificationLink.foreground": "#D4B46C",
		"peekView.border": "#B89848",
		"peekViewEditor.background": "#1E1D1C",
		"peekViewResult.background": "#141310",
		"peekViewTitle.background": "#1E1D1C",
		"peekViewEditor.matchHighlightBackground": "#B898D440",
		"peekViewResult.matchHighlightBackground": "#B898D440",
		"gitDecoration.modifiedResourceForeground": "#80A8E0",
		"gitDecoration.deletedResourceForeground": "#F07878",
		"gitDecoration.untrackedResourceForeground": "#78E0A0",
		"gitDecoration.ignoredResourceForeground": "#5E5640",
		"gitDecoration.conflictingResourceForeground": "#E8C878",
		"diffEditor.insertedTextBackground": "#78E0A018",
		"diffEditor.removedTextBackground": "#F0787818",
		"editorWidget.background": "#1E1D1C",
		"editorWidget.border": "#282418",
		"editorSuggestWidget.background": "#1E1D1C",
		"editorSuggestWidget.border": "#282418",
		"editorSuggestWidget.foreground": "#E8E4D8",
		"editorSuggestWidget.selectedBackground": "#302818",
		"editorSuggestWidget.highlightForeground": "#D4B46C",
		"editorHoverWidget.background": "#1E1D1C",
		"editorHoverWidget.border": "#282418"
	},
	"tokenColors": [
		{
			"scope": "comment",
			"settings": {
				"foreground": "#6A6040",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.other"
			],
			"settings": {
				"foreground": "#D4B46C",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"storage.type",
				"storage.modifier",
				"storage"
			],
			"settings": {
				"foreground": "#D4B46C",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from"
			],
			"settings": {
				"foreground": "#B09050",
				"fontStyle": ""
			}
		},
		{
			"scope": "string",
			"settings": {
				"foreground": "#E890B8"
			}
		},
		{
			"scope": "string.regexp",
			"settings": {
				"foreground": "#D880A8"
			}
		},
		{
			"scope": "constant.character.escape",
			"settings": {
				"foreground": "#C870A0",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "variable",
			"settings": {
				"foreground": "#C8C0B8"
			}
		},
		{
			"scope": "variable.parameter",
			"settings": {
				"foreground": "#B8B0A8",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable.other.property",
				"support.variable.property"
			],
			"settings": {
				"foreground": "#D0C8C0"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call"
			],
			"settings": {
				"foreground": "#B898D4",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"support.class",
				"entity.name.class"
			],
			"settings": {
				"foreground": "#72D0C0",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"entity.name.enum",
				"entity.name.type.enum"
			],
			"settings": {
				"foreground": "#9CC888",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"constant",
				"constant.language",
				"support.constant",
				"variable.other.constant"
			],
			"settings": {
				"foreground": "#84D8B0",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"constant.numeric",
				"number"
			],
			"settings": {
				"foreground": "#78CCA8"
			}
		},
		{
			"scope": [
				"keyword.operator",
				"operator",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#C0A868"
			}
		},
		{
			"scope": "punctuation",
			"settings": {
				"foreground": "#9898A0"
			}
		},
		{
			"scope": [
				"punctuation.definition.block",
				"punctuation.definition.parameters",
				"punctuation.section",
				"punctuation.definition.arguments"
			],
			"settings": {
				"foreground": "#A8A8B0"
			}
		},
		{
			"scope": "entity.name.tag",
			"settings": {
				"foreground": "#72D0C0"
			}
		},
		{
			"scope": "entity.other.attribute-name",
			"settings": {
				"foreground": "#B898D4",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"meta.decorator",
				"punctuation.decorator"
			],
			"settings": {
				"foreground": "#84B4DC",
				"fontStyle": "italic"
			}
		},
		{
			"scope": "support.type",
			"settings": {
				"foreground": "#D890B0"
			}
		},
		{
			"scope": "markup.heading",
			"settings": {
				"foreground": "#D4B46C",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "markup.underline",
			"settings": {
				"fontStyle": "underline"
			}
		},
		{
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#78E0A0"
			}
		},
		{
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#F07878"
			}
		},
		{
			"scope": "markup.changed",
			"settings": {
				"foreground": "#B898D4"
			}
		},
		{
			"scope": [
				"markup.inline.raw",
				"markup.fenced_code"
			],
			"settings": {
				"foreground": "#E890B8"
			}
		},
		{
			"scope": "meta.embedded",
			"settings": {
				"foreground": "#E8E4D8"
			}
		},
		{
			"scope": "invalid",
			"settings": {
				"foreground": "#FFFFFF",
				"fontStyle": "underline"
			}
		}
	]
}

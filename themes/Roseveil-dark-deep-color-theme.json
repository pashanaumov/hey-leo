		"editor.wordHighlightBackground": "#260E1344",
		"editor.wordHighlightStrongBackground": "#260E1344",
		"editor.findMatchBackground": "#B890D440",
		"editor.findMatchHighlightBackground": "#B890D425",
		"editorLineNumber.foreground": "#4B3C3F",
		"editorLineNumber.activeForeground": "#D06878",
		"editorIndentGuide.background": "#151012",
		"editorIndentGuide.activeBackground": "#1B1518",
		"editorWhitespace.foreground": "#1B1518",
		"editorBracketMatch.background": "#190C0E",
		"editorBracketMatch.border": "#D06070",
		"editorBracketHighlight.foreground1": "#F07888",
		"editorBracketHighlight.foreground2": "#6CD8D0",
		"editorBracketHighlight.foreground3": "#B890D4",
		"editorBracketHighlight.foreground4": "#D4B068",
		"editorBracketHighlight.foreground5": "#F098A4",
		"editorBracketHighlight.foreground6": "#88C89A",
		"editorError.foreground": "#F07878",
		"editorWarning.foreground": "#E8C878",
		"editorInfo.foreground": "#80C0E8",
		"editorGutter.modifiedBackground": "#5E82C9",
		"editorGutter.addedBackground": "#5CCC9D",
		"editorGutter.deletedBackground": "#D8645A",
		"editorOverviewRuler.border": "#160E13",
		"editorOverviewRuler.errorForeground": "#F07878",
		"editorOverviewRuler.warningForeground": "#E8C878",
		"editorOverviewRuler.infoForeground": "#80C0E8",
		"sideBar.background": "#0D0A0B",
		"sideBar.foreground": "#A89898",
		"sideBarTitle.foreground": "#C4B0B4",
		"sideBarSectionHeader.background": "#121012",
		"sideBarSectionHeader.foreground": "#C8C0C2",
		"list.activeSelectionBackground": "#210E10",
		"list.activeSelectionForeground": "#E4DCDE",
		"list.hoverBackground": "#130F10",
		"list.focusBackground": "#1B090E",
		"list.highlightForeground": "#F07888",
		"list.inactiveSelectionBackground": "#180C0D",
		"activityBar.background": "#0B0909",
		"activityBar.foreground": "#D06070",
		"activityBar.inactiveForeground": "#4B3C3F",
		"activityBarBadge.background": "#F07888",
		"activityBarBadge.foreground": "#FFFFFF",
		"statusBar.background": "#0E0C0D",
		"statusBar.foreground": "#A89898",
		"statusBar.debuggingBackground": "#260E13",
		"statusBar.debuggingForeground": "#E4DCDE",
		"statusBar.noFolderBackground": "#121012",
		"titleBar.activeBackground": "#0B0909",
		"titleBar.activeForeground": "#C4B0B4",
		"titleBar.inactiveBackground": "#090707",
		"titleBar.inactiveForeground": "#4B3C3F",
		"editorGroupHeader.tabsBackground": "#0D0A0B",
		"tab.activeBackground": "#131012",
		"tab.inactiveBackground": "#0D0A0B",
		"tab.activeForeground": "#E4DCDE",
		"tab.inactiveForeground": "#4B3C3F",
		"tab.activeBorderTop": "#F07888",
		"tab.hoverBackground": "#121012",
		"tab.border": "#0D0A0B",
		"panel.background": "#0F0D0E",
		"panel.border": "#160E13",
		"panelTitle.activeForeground": "#E4DCDE",
		"panelTitle.activeBorder": "#F07888",
		"panelTitle.inactiveForeground": "#4B3C3F",
		"terminal.background": "#100E0F",
		"terminal.foreground": "#E4DCDE",
		"terminal.ansiBlack": "#2A1818",
		"terminal.ansiRed": "#F07878",
		"terminal.ansiGreen": "#78E0A0",
		"terminal.ansiYellow": "#E8C878",
		"terminal.ansiBlue": "#80A8E0",
		"terminal.ansiMagenta": "#D87888",
		"terminal.ansiCyan": "#78D8D0",
		"terminal.ansiWhite": "#B0A8A8",
		"terminal.ansiBrightBlack": "#423030",
		"terminal.ansiBrightRed": "#FF9090",
		"terminal.ansiBrightGreen": "#90F8B8",
		"terminal.ansiBrightYellow": "#FFE090",
		"terminal.ansiBrightBlue": "#98C0F8",
		"terminal.ansiBrightMagenta": "#F090A0",
		"terminal.ansiBrightCyan": "#90F0E8",
		"terminal.ansiBrightWhite": "#C8C0C0",
		"focusBorder": "#D06070",
		"input.background": "#131012",
		"input.foreground": "#E4DCDE",
		"input.border": "#160E13",
		"input.placeholderForeground": "#4B3C3F",
		"inputOption.activeBorder": "#F07888",
		"button.background": "#F07888",
		"button.foreground": "#FFFFFF",
		"button.hoverBackground": "#FF90A0",
		"button.secondaryBackground": "#210E10",
		"button.secondaryForeground": "#C4B0B4",
		"button.secondaryHoverBackground": "#1B090E",
		"dropdown.background": "#131012",
		"dropdown.foreground": "#E4DCDE",
		"dropdown.border": "#160E13",
		"badge.background": "#F07888",
		"badge.foreground": "#FFFFFF",
		"progressBar.background": "#F07888",
		"scrollbarSlider.background": "#260E1388",
		"scrollbarSlider.hoverBackground": "#1B090E88",
		"scrollbarSlider.activeBackground": "#A84E6099",
		"minimap.selectionHighlight": "#F0788840",
		"minimapSlider.background": "#260E1344",
		"minimapSlider.hoverBackground": "#1B090E66",
		"minimapSlider.activeBackground": "#A84E6088",
		"breadcrumb.foreground": "#908080",
		"breadcrumb.focusForeground": "#C4B0B4",
		"breadcrumb.activeSelectionForeground": "#E4DCDE",
		"notificationCenter.border": "#160E13",
		"notifications.background": "#131012",
		"notifications.foreground": "#E4DCDE",
		"notificationLink.foreground": "#F07888",
		"peekView.border": "#D06070",
		"peekViewEditor.background": "#131012",
		"peekViewResult.background": "#0D0A0B",
		"peekViewTitle.background": "#131012",
		"peekViewEditor.matchHighlightBackground": "#B890D440",
		"peekViewResult.matchHighlightBackground": "#B890D440",
		"gitDecoration.modifiedResourceForeground": "#80A8E0",
		"gitDecoration.deletedResourceForeground": "#F07878",
		"gitDecoration.untrackedResourceForeground": "#78E0A0",
		"gitDecoration.ignoredResourceForeground": "#4B3C3F",
		"gitDecoration.conflictingResourceForeground": "#E8C878",
		"diffEditor.insertedTextBackground": "#78E0A018",
		"diffEditor.removedTextBackground": "#F0787818",
		"editorWidget.background": "#131012",
		"editorWidget.border": "#160E13",
		"editorSuggestWidget.background": "#131012",
		"editorSuggestWidget.border": "#160E13",
		"editorSuggestWidget.foreground": "#E4DCDE",
		"editorSuggestWidget.selectedBackground": "#210E10",
		"editorSuggestWidget.highlightForeground": "#F07888",
		"editorHoverWidget.background": "#131012",
		"editorHoverWidget.border": "#160E13"
	},
	"tokenColors": [
		{
			"scope": "comment",
			"settings": {
				"foreground": "#6A4A50",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.other"
			],
			"settings": {
				"foreground": "#F07888",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"storage.type",
				"storage.modifier",
				"storage"
			],
			"settings": {
				"foreground": "#F07888",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from"
			],
			"settings": {
				"foreground": "#C86878",
				"fontStyle": ""
			}
		},
		{
			"scope": "string",
			"settings": {
				"foreground": "#6CD8D0"
			}
		},
		{
			"scope": "string.regexp",
			"settings": {
				"foreground": "#58C8C0"
			}
		},
		{
			"scope": "constant.character.escape",
			"settings": {
				"foreground": "#4CC0B8",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "variable",
			"settings": {
				"foreground": "#C4B8BA"
			}
		},
		{
			"scope": "variable.parameter",
			"settings": {
				"foreground": "#B4A8AA",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable.other.property",
				"support.variable.property"
			],
			"settings": {
				"foreground": "#CCC0C2"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call"
			],
			"settings": {
				"foreground": "#B890D4",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"support.class",
				"entity.name.class"
			],
			"settings": {
				"foreground": "#D4B068",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"entity.name.enum",
				"entity.name.type.enum"
			],
			"settings": {
				"foreground": "#88C89A",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"constant",
				"constant.language",
				"support.constant",
				"variable.other.constant"
			],
			"settings": {
				"foreground": "#F098A4",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"constant.numeric",
				"number"
			],
			"settings": {
				"foreground": "#E89094"
			}
		},
		{
			"scope": [
				"keyword.operator",
				"operator",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#C07888"
			}
		},
		{
			"scope": "punctuation",
			"settings": {
				"foreground": "#9A8888"
			}
		},
		{
			"scope": [
				"punctuation.definition.block",
				"punctuation.definition.parameters",
				"punctuation.section",
				"punctuation.definition.arguments"
			],
			"settings": {
				"foreground": "#AA9898"
			}
		},
		{
			"scope": "entity.name.tag",
			"settings": {
				"foreground": "#D4B068"
			}
		},
		{
			"scope": "entity.other.attribute-name",
			"settings": {
				"foreground": "#B890D4",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"meta.decorator",
				"punctuation.decorator"
			],
			"settings": {
				"foreground": "#88B4DC",
				"fontStyle": "italic"
			}
		},
		{
			"scope": "support.type",
			"settings": {
				"foreground": "#C888A0"
			}
		},
		{
			"scope": "markup.heading",
			"settings": {
				"foreground": "#F07888",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "markup.underline",
			"settings": {
				"fontStyle": "underline"
			}
		},
		{
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#78E0A0"
			}
		},
		{
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#F07878"
			}
		},
		{
			"scope": "markup.changed",
			"settings": {
				"foreground": "#B890D4"
			}
		},
		{
			"scope": [
				"markup.inline.raw",
				"markup.fenced_code"
			],
			"settings": {
				"foreground": "#6CD8D0"
			}
		},
		{
			"scope": "meta.embedded",
			"settings": {
				"foreground": "#E4DCDE"
			}
		},
		{
			"scope": "invalid",
			"settings": {
				"foreground": "#FFFFFF",
				"fontStyle": "underline"
			}
		}
	]
}

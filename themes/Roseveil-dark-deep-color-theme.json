{
	"$schema": "vscode://schemas/color-theme",
	"name": "Leo Petal Dark Deep",
	"type": "vs-dark",
	"colors": {
		"editor.background": "#100E0F",
		"editor.foreground": "#E4DCDE",
		"editorCursor.foreground": "#F07888",
		"editor.lineHighlightBackground": "#131012",
		"editor.selectionBackground": "#260E13",

{
  "name": "leo-themes",
  "displayName": "Hey Leo",
  "description": "Curated pastel themes for Visual Studio Code: Leo Dew, Leo Morning, and Leo Velvet in Dark, Dark Deep, and Light variants.",
  "publisher": "pashanaumov",
  "version": "1.1.0",
  "icon": "icons/icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.87.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "vscode theme",
    "dark theme",
    "light theme",
    "pastel theme",
    "pastel dark",
    "pastel light",
    "catppuccin inspired",
    "dachshund",
    "soft syntax highlighting",
    "elegant dark theme",
    "developer aesthetic",
    "pretty themes",
    "deep dark",
    "oled theme",
    "vscode ui theme"
  ],
  "scripts": {
    "generate": "node scripts/generate-themes.mjs",
    "package": "npm run generate && npx @vscode/vsce package",
    "package:check": "npm run generate && npx @vscode/vsce ls",
    "package:profile": "node scripts/package-profile-extension.mjs"
  },
  "contributes": {
    "themes": [
      {
        "label": "Leo Velvet Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/LeoVelvet-dark-color-theme.json"
      },
      {
        "label": "Leo Velvet Dark Deep",
        "uiTheme": "vs-dark",
        "path": "./themes/LeoVelvet-dark-deep-color-theme.json"
      },
      {
        "label": "Leo Velvet Light",
        "uiTheme": "vs",
        "path": "./themes/LeoVelvet-light-color-theme.json"
      },
      {
        "label": "Leo Dew Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/LeoDew-dark-color-theme.json"
      },
      {
        "label": "Leo Dew Dark Deep",
        "uiTheme": "vs-dark",
        "path": "./themes/LeoDew-dark-deep-color-theme.json"
      },
      {
        "label": "Leo Dew Light",
        "uiTheme": "vs",
        "path": "./themes/LeoDew-light-color-theme.json"
      },
      {
        "label": "Leo Morning Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/LeoMorning-dark-color-theme.json"
      },
      {
        "label": "Leo Morning Dark Deep",
        "uiTheme": "vs-dark",
        "path": "./themes/LeoMorning-dark-deep-color-theme.json"
      },
      {
        "label": "Leo Morning Light",
        "uiTheme": "vs",
        "path": "./themes/LeoMorning-light-color-theme.json"
      }
    ]
  },
  "galleryBanner": {
    "color": "#1A1828",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pashanaumov/leo-themes"
  },
  "homepage": "https://github.com/pashanaumov/leo-themes#readme",
  "bugs": {
    "url": "https://github.com/pashanaumov/leo-themes/issues"
  }
}
